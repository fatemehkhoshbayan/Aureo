DATABASE_URL=postgresql+psycopg2://aureo:aureo@localhost:5432/aureo
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:4200,http://localhost:8000
SEED_ON_STARTUP=true
AUTO_CREATE_TABLES=true

# Leave SMTP_HOST empty to log emails to the backend console.
#
# Recommended (no domain needed, sends to ANY recipient): use Gmail as the
# SMTP relay via an "App Password" (not your normal password):
#   1. Enable 2-Step Verification on your Google account
#   2. Visit https://myaccount.google.com/apppasswords and create one for "Mail"
#   3. Use the 16-character password below (spaces don't matter)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=Aureo <your-address@gmail.com>
SMTP_TLS=true
